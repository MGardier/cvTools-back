// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}






// ================================================
//                  USER
// ================================================

enum UserStatus {
  ALLOWED
  PENDING
  BANNED
}

enum UserRoles {
  ADMIN
  USER
}

enum LoginMethod {
  CLASSIC
  GITHUB
  GOOGLE
}

model User {
  @@map("user")

  // Int
  id          Int        @id @default(autoincrement())

  // String
  email       String     @unique @db.VarChar(100)
  password    String?    @db.VarChar(150)
  oauthId     String?    @map("oauth_id") @db.VarChar(150)

  // DateTime
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime?  @updatedAt @map("updated_at")

  // Enum
  status      UserStatus  @default(ALLOWED)
  roles       UserRoles
  loginMethod LoginMethod @map("login_method")

  // Relations
  tokens                UserToken[]
  applications          Application[]
  jobboards             Jobboard[]
  skills                Skill[]
  contacts              Contact[]
  providerLogs          ProviderLogger[]
  providerUsageRecords  ProviderUsageRecord[]

  @@unique([loginMethod, oauthId], name: "unique_oauth_user")
}


// ================================================
//                  USER TOKEN
// ================================================



enum PrismaTokenType {
  REFRESH
  FORGOT_PASSWORD
  CONFIRM_ACCOUNT
}


model UserToken {
  @@map("user_token")

  // Int
  id        Int             @id @default(autoincrement())

  // String
  token     String          @db.Text
  uuid      String?         @unique @db.VarChar(150)

  // DateTime
  expiresAt DateTime        @map("expires_at")
  createdAt DateTime        @default(now()) @map("created_at")

  // Enum
  type      PrismaTokenType

  // Foreign keys
  userId    Int             @map("user_id")

  //Relations
  user      User            @relation(fields: [userId], references: [id])
}


// ================================================
//                  PROVIDER LOGGER
// ================================================

enum ExternalProvider {
  CHATGPT
  CLAUDE
  ADZUNA
  FRANCE_TRAVAIL
  APIFY
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
  DELETE
}


model ProviderLogger {
  @@map("provider_logger")

  // Int
  id            Int    @id @default(autoincrement())
  statusCode    Int    @map("status_code") @db.SmallInt

  // String
  operationPath String @map("operation_path") @db.VarChar(50)

  // DateTime
  createdAt     DateTime @default(now()) @map("created_at")

  // Enum
  method        HttpMethod
  provider      ExternalProvider

  // Json
  request       Json
  response      Json

  // Foreign keys
  usedBy        Int  @map("used_by")
  user          User @relation(fields: [usedBy], references: [id])

  @@index([usedBy])
  @@index([provider])
}

// ================================================
//                  PROVIDER USAGE RECORD
// ================================================

model ProviderUsageRecord {
  @@map("provider_usage_record")

  // Int
  id             Int    @id @default(autoincrement())
  requestCount   Int    @default(0) @map("request_count")
  tokensConsumed Int    @default(0) @map("tokens_consumed")

  // DateTime
  periodStartAt  DateTime  @map("period_start_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime? @updatedAt @map("updated_at")

  // Enum
  provider       ExternalProvider

  // Foreign keys
  userId         Int  @map("user_id")

  //Relations
  user           User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([provider])
  @@unique([userId, provider, periodStartAt])
}

// ================================================
//                  JOBBOARD
// ================================================

model Jobboard {
  @@map("jobboard")

  // Int
  id        Int       @id @default(autoincrement())

  // String
  label     String    @db.VarChar(150)

  // DateTime
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  // Foreign keys
  createdBy Int       @map("created_by")

  // Relations
  creator   User      @relation(fields: [createdBy], references: [id])
  applications Application[]

  @@index([createdBy])
}

// ================================================
//                  ADDRESS (polymorphic)
// ================================================

enum AddressTable {
  APPLICATION
}



model Address {
  @@map("address")

  // Int
  id           Int          @id @default(autoincrement())

  // String
  city         String       @db.VarChar(100)
  postalCode   String       @map("postal_code") @db.VarChar(10)
  street       String?      @db.VarChar(100)
  complement   String?      @db.VarChar(100)
  streetNumber String?      @map("street_number") @db.VarChar(10)

  // DateTime
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime?    @updatedAt @map("updated_at")

  // Relations
  tableName    AddressTable @map("table_name")
  tableId      Int          @map("table_id")

  @@index([tableName, tableId])
}

// ================================================
//                  APPLICATION
// ================================================


enum ApiProvider {
  ADZUNA
  APIFY
  FRANCE_TRAVAIL
  UNKNOW
}

enum ContractType {
  CDI
  CDD
  FREELANCE
  ALTERNANCE
}

enum ExperienceLevel {
  JUNIOR
  MID
  SENIOR
}

enum RemotePolicy {
  FULL
  HYBRID
  ONSITE
}

enum ApplicationStatus {
  NEED_TO_APPLY
  APPLIED
  IN_PROCESS
  COMPANY_OFFER_RECEIVED
  ACCEPTED
  REJECTED
  GHOSTED
  WITHDRAWN
}

enum CompatibilityJob {
  PERFECT
  ATTAINABLE
  WHY_NOT
}

 

model Application {
  @@map("application")

  // Int
  id           Int       @id @default(autoincrement())

  // String
  apiOfferId   String?   @map("api_offer_id") @db.VarChar(150)
  title        String    @db.VarChar(100)
  company      String?   @db.VarChar(100)
  url          String    @db.Text
  description  String?   @db.Text

  // DateTime
  publishedAt  DateTime?  @map("published_at")
  appliedAt    DateTime?  @map("applied_at")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime?  @updatedAt @map("updated_at")

  // Boolean
  isFavorite   Boolean    @default(false) @map("is_favorite")

  // Enum
  apiProvider    ApiProvider?       @map("api_provider")
  contractType   ContractType       @map("contract_type")
  experience     ExperienceLevel?
  remotePolicy   RemotePolicy?      @map("remote_policy")
  compatibility  CompatibilityJob?
  currentStatus  ApplicationStatus  @default(NEED_TO_APPLY) @map("current_status")

  // Decimal
  salaryMin    Decimal?   @map("salary_min")
  salaryMax    Decimal?   @map("salary_max")

  // Foreign keys
  userId       Int        @map("user_id")
  jobboardId   Int        @map("jobboard_id")


  // Relations
  user                 User       @relation(fields: [userId], references: [id])
  jobboard             Jobboard   @relation(fields: [jobboardId], references: [id])
  contacts             Contact[]
  applicationSkills    ApplicationHasSkill[]
  activities           ApplicationHistory[]
  todos                Todo[]
  notes                Note[]

  @@index([userId])
  @@index([jobboardId])
  @@index([currentStatus])
}

// ================================================
//                  CONTACT
// ================================================

model Contact {
  @@map("contact")

  // Int
  id         Int       @id @default(autoincrement())
  createdBy  Int       @map("created_by")

  // String
  firstname  String    @db.VarChar(100)
  lastname   String    @db.VarChar(100)
  email      String    @db.VarChar(100)
  phone      String?   @db.VarChar(20)
  profession String    @db.VarChar(50)

  // DateTime
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  // Foreign keys
  applicationId Int @map("application_id")

  // Relations
  user        User        @relation(fields: [createdBy], references: [id])
  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([createdBy])
  @@index([applicationId])
}

// ================================================
//                  SKILL
// ================================================

model Skill {
  @@map("skill")

  // Int
  id        Int       @id @default(autoincrement())

  // String
  label     String    @unique @db.VarChar(100)

  // DateTime
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  // Foreign keys
  createdBy Int       @map("created_by")
  

  // Relations
  creator   User      @relation(fields: [createdBy], references: [id])
  applicationSkills ApplicationHasSkill[]
}

// ================================================
//        APPLICATION_HAS_SKILL (junction table)
// ================================================

model ApplicationHasSkill {
  @@map("application_has_skill")

  // Foreign keys
  applicationId Int         @map("application_id")
  skillId       Int         @map("skill_id")
  
  //Relations
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  skill         Skill       @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([applicationId, skillId])
  @@index([skillId])
}

// ================================================
//                  APPLICATION HISTORY
// ================================================

model ApplicationHistory {
  @@map("application_history")

  // Int
  id          Int               @id @default(autoincrement())

  // String
  description String            @db.VarChar(255)

  // DateTime
  doneAt      DateTime?         @map("done_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime?         @updatedAt @map("updated_at")

  // Enum
  status      ApplicationStatus

  // Foreign keys
  applicationId Int         @map("application_id")
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@index([doneAt])
}

// ================================================
//                  TODO
// ================================================

enum StatusTodo {
  TO_MAKE
  IN_PROGRESS
  DONE
  ARCHIVED
}


model Todo {
  @@map("todo")

  // Int
  id          Int        @id @default(autoincrement())

  // String
  description String     @db.VarChar(150)

  // DateTime
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime?  @updatedAt @map("updated_at")

  // Enum
  status      StatusTodo @default(TO_MAKE)

  // Foreign keys
  applicationId Int         @map("application_id")

  //Relations
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}

// ================================================
//                  NOTE
// ================================================

model Note {
  @@map("note")

  // Int
  id          Int       @id @default(autoincrement())

  // String
  description String    @db.Text

  // DateTime
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")

  // Foreign keys
  applicationId Int         @map("application_id")

  //Relations
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
}


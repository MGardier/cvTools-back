// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//================================================
//                  AUTH
//================================================

enum UserStatus {
  ALLOWED
  PENDING
  BANNED
}

enum UserRoles {
  ADMIN
  USER
}

enum PrismaTokenType {
  REFRESH
  FORGOT_PASSWORD
  CONFIRM_ACCOUNT
}

enum LoginMethod {
  CLASSIC
  GITHUB
  GOOGLE
}

model User {
  @@map("user")

  id          Int        @id @default(autoincrement())
  email       String     @unique
  status      UserStatus @default(ALLOWED)
  password    String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime?  @updatedAt @map("updated_at")
  roles       UserRoles
  tokens      UserToken[]
  loginMethod LoginMethod
  oauthId     String?    @map("oauth_id")

  // Relations
  jobs                     Job[]
  externalProviderHistorics ExternalProviderHistoric[]

  @@unique([loginMethod, oauthId], name: "unique_oauth_user")
}

model UserToken {
  @@map("user_token")

  id        Int             @id @default(autoincrement())
  token     String          @db.Text
  type      PrismaTokenType
  expiresIn DateTime        @map("expires_in")
  uuid      String?         @unique
  createdAt DateTime        @default(now()) @map("created_at")
  userId    Int             @map("user_id")
  user      User            @relation(fields: [userId], references: [id])
}

//================================================
//                  ADDRESS
//================================================

model Address {
  @@map("address")

  id         Int       @id @default(autoincrement())
  city       String
  postalCode String    @map("postal_code")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime? @updatedAt @map("updated_at")

  // Relations
  jobs Job[]

  @@unique([city, postalCode], name: "city_postalCode")
}

//================================================
//                  JOB
//================================================

enum ApiProvider {
  ADZUNA
  APIFY
  FRANCE_TRAVAIL
  UNKNOW
}

enum ContractType {
  CDI
  CDD
  FREELANCE
  ALTERNANCE
}

enum JobOrigin {
  FRANCE_TRAVAIL
  INDEED
  WTTJ
  HELLOWORK
  LINKEDIN
  USER
  UNKNOW
}

enum ExperienceLevel {
  JUNIOR
  MID
  SENIOR
}

enum RemotePolicy {
  FULL
  HYBRID
  ONSITE
}

enum JobStatus {
  BOOKMARKED
  NEED_TO_APPLY
  APPLIED
  IN_PROCESS
  COMPANY_OFFER_RECEIVED
  ACCEPTED
  REJECTED
  GHOSTED
  WITHDRAWN
  ARCHIVED
}

enum CompatibilityJob {
  PERFECT
  ATTAINABLE
  WHY_NOT
}

model Job {
  @@map("job")

  //INt
  id            Int              @id @default(autoincrement())
  salaryMin     Int?             @map("salary_min")
  salaryMax     Int?             @map("salary_max")

  //String

  title         String
  url           String
  company       String?
  apiOfferId    String?          @map("api_offer_id")
  description   String?          @db.Text
  rejectedReason String?         @map("rejected_reason")

  // Enum
  origin        JobOrigin
  status        JobStatus        @default(BOOKMARKED)
  apiProvider   ApiProvider?      @map("api_provider")
  contractType  ContractType?    @map("contract_type")
  experience    ExperienceLevel?
  remotePolicy  RemotePolicy?    @map("remote_policy") 
  compatibility CompatibilityJob?

  //DateTime
  createdAt     DateTime         @default(now()) @map("created_at")
  publishedAt   DateTime         @map("published_at")
  appliedAt     DateTime?        @map("applied_at")
  updatedAt     DateTime?        @updatedAt @map("updated_at")

  // Foreign keys
  userId    Int  @map("user_id")
  addressId Int? @map("address_id")

  // Relations
  user       User          @relation(fields: [userId], references: [id])
  address    Address?      @relation(fields: [addressId], references: [id])
  contacts   Contact[]
  jobSkills  JobSkill[]
  activities JobActivity[]
  todos      Todo[]
  notes      Note[]

  @@index([userId])
  @@index([status])
}

// ========================================
// CONTACTS
// ========================================

model Contact {
  @@map("contact")

  id        Int       @id @default(autoincrement())
  name      String
  email     String?
  phone     String?
  role      String?   // "RH", "Tech Lead", "CTO"...
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  // Foreign keys
  jobId Int @map("job_id")

  // Relations
  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

// ========================================
// SKILLS 
// ========================================

model Skill {
  @@map("skill")

  id        Int        @id @default(autoincrement())
  name      String     @unique
  createdAt DateTime   @default(now()) @map("created_at")

  // Relations
  jobSkills JobSkill[]
}

model JobSkill {
  @@map("job_skill")

  jobId   Int @map("job_id")
  skillId Int @map("skill_id")

  // Relations
  job   Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([jobId, skillId])
  @@index([skillId])
}

// ========================================
// JOB ACTIVITES (Timeline / Activity Log)
// ========================================

enum ActionType {
  SYSTEM
  USER
}

model JobActivity {
  @@map("job_activity")

  id          Int        @id @default(autoincrement())
  label       String
  description String?    @db.Text
  type        ActionType
  statusFrom  JobStatus? @map("status_from")
  statusTo    JobStatus? @map("status_to")
  doneAt      DateTime   @map("done_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime?  @updatedAt @map("updated_at")

  // Foreign keys
  jobId Int @map("job_id")

  // Relations
  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
  @@index([doneAt])
}

// ========================================
// TODOS
// ========================================

enum StatusTodo {
  TO_MAKE
  IN_PROGRESS
  DONE
  ARCHIVED
}

model Todo {
  @@map("todo")

  id        Int        @id @default(autoincrement())
  label     String
  status    StatusTodo  @default(TO_MAKE)
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime?  @updatedAt @map("updated_at")

  // Foreign keys
  jobId Int @map("job_id")

  // Relations
  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

// ========================================
// NOTES
// ========================================

model Note {
  @@map("note")

  id        Int       @id @default(autoincrement())
  content   String    @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @updatedAt @map("updated_at")

  // Foreign keys
  jobId Int @map("job_id")

  // Relations
  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}

// ========================================
// EXTERNAL PROVIDER HISTORIC  
// ========================================

enum ExternalProvider {
  CHATGPT
  CLAUDE
  ADZUNA
  FRANCE_TRAVAIL
  APIFY
}

model ExternalProviderHistoric {
  @@map("external_provider_historic")

  id            Int              @id @default(autoincrement())
  provider      ExternalProvider
  operationPath String           @map("operation_path")
  createdAt DateTime  @default(now()) @map("created_at")

  // Foreign keys
  userId Int @map("user_id")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([provider])
}
